# ===== Cấu hình kết nối Backend =====
# VITE_USE_MOCK=true  → toàn bộ dùng mock (FE chạy độc lập, không cần BE).
# VITE_USE_MOCK=false → các endpoint ĐÃ có BE (login/register) gọi BE thật;
#                       phần còn lại (products/orders/custom/supplier...) vẫn tự động dùng mock
#                       vì BE chưa làm (xem REAL_ENDPOINTS trong src/api/client.js).
VITE_USE_MOCK=false

# URL gốc của BE Spring Boot (cổng mặc định 8081, đã gồm tiền tố /api)
VITE_API_URL=http://localhost:8081/api

# Google OAuth client ID (trùng với app.google.client-id của BE) — cho nút "Đăng nhập bằng Google".
# Bỏ trống hoặc khi VITE_USE_MOCK=true thì nút Google chạy ở chế độ demo (không gọi Google thật).
VITE_GOOGLE_CLIENT_ID=
